    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "eslint": "^9.7.0",
    "gh-pages": "^6.3.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.9.1",
    "office-addin-debugging": "^5.0.0",
    "office-addin-dev-certs": "^1.0.0",
    "office-addin-manifest": "^1.0.0",
    "ts-jest": "^29.2.4",
